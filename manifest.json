{
  "manifest_version": 2,
  "name": "Inferfox SmartPace",
  "version": "1.0.2",
  "description": "Learn a comfortable YouTube playback pace per channel.",
  "permissions": [
    "storage",
    "*://*.youtube.com/*"
  ],
  "background": {
    "scripts": ["src/model.js", "src/controller.js", "src/storage.js", "src/background.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["src/model.js", "src/session.js", "src/controller.js", "src/storage.js", "src/content_script.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    "assets/fonts/Orbitron-Bold.woff2"
  ],
  "options_ui": {
    "page": "src/options.html",
    "open_in_tab": true
  },
  "browser_action": {
    "default_title": "Inferfox SmartPace",
    "default_popup": "src/popup.html",
    "default_icon": {
      "48": "assets/icon-48.png",
      "96": "assets/icon-96.png"
    }
  },
  "icons": {
    "48": "assets/icon-48.png",
    "96": "assets/icon-96.png",
    "128": "assets/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "inferfox-smartpace@local-first.tools",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
