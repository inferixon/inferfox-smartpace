{
  "manifest_version": 2,
  "name": "Inferfox SmartPace",
  "version": "0.1.0",
  "description": "Learn a comfortable YouTube playback pace per channel.",
  "permissions": [
    "storage"
  ],
  "options_ui": {
    "page": "src/options.html",
    "open_in_tab": true
  },
  "browser_action": {
    "default_title": "Inferfox SmartPace",
    "default_popup": "src/popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "smartpace-youtube@local-first.tools",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
